# 遇己 - 环境变量配置
# 复制此文件为 .env.local 并填入你的 Supabase 配置

# Supabase 项目 URL（从 Supabase Dashboard -> Settings -> API 获取）
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase 匿名密钥（从 Supabase Dashboard -> Settings -> API 获取）
# 注意：这是公开的匿名密钥，不是 secret 密钥
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# 可选：用于服务端验证的密钥（如果需要）
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
